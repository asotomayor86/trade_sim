# =============================================================================
# trade_sim — Variables de entorno
# Copia este archivo como .env.local y rellena los valores reales.
# NUNCA commitees .env.local ni .env al repositorio.
# =============================================================================

# Base de datos
# Local (docker-compose): postgresql://trade_sim:trade_sim_local@localhost:5432/trade_sim?schema=public
# Neon (producción, pooled — para el app runtime):
DATABASE_URL="postgresql://user:pass@host-pooler.neon.tech/neondb?channel_binding=require&connect_timeout=15&sslmode=require"
# Neon (producción, directo — para prisma migrate):
DATABASE_URL_UNPOOLED="postgresql://user:pass@host.neon.tech/neondb?sslmode=require"

# Auth.js — genera con: openssl rand -base64 32
AUTH_SECRET="CAMBIA_ESTO_EN_PRODUCCION"
AUTH_URL="http://localhost:3000"

# Alpaca Markets (Paper Trading API — feed IEX, delayed 15 min)
ALPACA_API_KEY="PKNDVB44FL2J77RCKOSPWGWQHN"
ALPACA_API_SECRET="DnpjCkez6iQutcNJirhTKqMVcpPVBsvysiNCB7swwinP"
ALPACA_BASE_URL="https://data.alpaca.markets"

# Vercel Cron — string aleatorio seguro
# Generar con: openssl rand -hex 32
CRON_SECRET="CAMBIA_ESTO_EN_PRODUCCION"

# Web Push VAPID — generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"

# Seed — usuario admin inicial (cambiar password tras primer login)
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="CAMBIA_ESTO_EN_PRODUCCION"
